#!/bin/bash
PLUG=$(acpi -a | grep -E -o ': \w+' | cut -d ":" -f 2 | xargs)
BAT=$(acpi -b | grep -v "rate information unavailable" | grep -E -o '[0-9]+%')

TEXT=""
ICON="яЙА  "
COLOR="$LAVENDER"

if [ "$PLUG" = 'on' ]; then
	ICON="яГз" COLOR="$GREEN"
else
	[ "${BAT%?}" -le 5 ] && ICON="яЙД  " && exit 33
	[ "${BAT%?}" -le 20 ] && ICON="яЙГ  " COLOR="$RED"
	[ "${BAT%?}" -le 50 ] && ICON="яЙВ  " COLOR="$PEACH"
	[ "${BAT%?}" -le 70 ] && ICON="яЙБ  " COLOR="$YELLOW"
	[ "${BAT%?}" -ge 70 ] && ICON="яЙА  "
fi

TEXT="$ICON $BAT"

echo "$TEXT"
echo "$ICON"
echo "$COLOR"

exit 0
